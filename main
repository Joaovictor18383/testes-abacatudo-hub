function AutoHaki()
	if not game:GetService("Players").LocalPlayer.Character:FindFirstChild("HasBuso") then
		game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("Buso")
	end
end;

function EquipWeapon(ToolSe)
	if not game.Players.LocalPlayer.Character:FindFirstChild(ToolSe) then
		if game.Players.LocalPlayer.Backpack:FindFirstChild(ToolSe) then
			local Tool = game.Players.LocalPlayer.Backpack:FindFirstChild(ToolSe);
			game.Players.LocalPlayer.Character.Humanoid:EquipTool(Tool);
		end;
	end;
end;

function topos(Pos)
	local Distance = (Pos.Position - game.Players.LocalPlayer.Character.HumanoidRootPart.Position).Magnitude;
	local tween = game:GetService("TweenService"):Create(game:GetService("Players").LocalPlayer.Character.HumanoidRootPart, TweenInfo.new(Distance / TweenSpeed, Enum.EasingStyle.Linear), {
		CFrame = Pos
	})
    tween:Play();
	return tween
end;

function AttackNoCD()
	if _G.AutoFarm or _G.AutoCombat then
		pcall(function()
			local tool = Char:FindFirstChildOfClass("Tool")
			if tool then
				tool:Activate()
			end
			-- Ataque mais robusto usando VirtualUser (funciona em todos os executores)
			VU:CaptureController()
			VU:Button1Down(Vector2.new(1280, 672)) -- Coordenada genérica que simula clique na tela
		end)
	end;
end;

-- Noclip otimizado: cache de partes para não pesar o processamento
local characterParts = {}
local function updateCharParts()
    characterParts = {}
    if Char then
        for _, v in pairs(Char:GetDescendants()) do
            if v:IsA("BasePart") then
                table.insert(characterParts, v)
            end
        end
    end
end

LP.CharacterAdded:Connect(function(c)
    Char = c
    HRP  = c:WaitForChild('HumanoidRootPart')
    Hum  = c:WaitForChild('Humanoid')
    updateCharParts()
end)
updateCharParts()

RunService.Stepped:Connect(function()
    if _G.AutoFarm or _G.AutoCombat then
        for i = 1, #characterParts do
            local part = characterParts[i]
            if part and part.Parent then
                part.CanCollide = false
            end
        end
    end
end)

-- Encontra mob mais próximo com busca otimizada
local function findMob(name)
    local best, bestDist = nil, math.huge
    
    -- Blox Fruits geralmente coloca mobs na pasta Enemies
    local enemiesFolder = workspace:FindFirstChild("Enemies")
    local searchArea = enemiesFolder and enemiesFolder:GetChildren() or workspace:GetChildren()
    
    for _, obj in ipairs(searchArea) do
        if obj.Name:find(name) and obj:FindFirstChild("HumanoidRootPart") then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local d = (obj.HumanoidRootPart.Position - HRP.Position).Magnitude
                if d < bestDist then
                    best, bestDist = obj, d
                end
            end
        end
    end
    
    return best
end

-- Verifica quest ativa de forma robusta
local function hasQuest()
    local ok, res = pcall(function()
        -- Verifica via dados do jogador
        local qv = LP:FindFirstChild('Data') and LP.Data:FindFirstChild('QuestV2')
        if qv and qv.Value ~= '' then return true end
        
        -- Verifica via GUI (Cobre 100% dos casos no Blox Fruits)
        local questGui = LP.PlayerGui:FindFirstChild("Main") and LP.PlayerGui.Main:FindFirstChild("Quest")
        if questGui and questGui.Visible then return true end
        
        return false
    end)
    return ok and res == true
end

-- Limpa interfaces de diálogo travadas
local function clearQuestUI()
    pcall(function()
        local mainGui = LP.PlayerGui:FindFirstChild("Main")
        if mainGui then
            -- Fecha diálogos genéricos de NPC se estiverem abertos e já tivermos quest
            local dialogue = mainGui:FindFirstChild("Dialog") or mainGui:FindFirstChild("NPC")
            if dialogue and dialogue.Visible then
                dialogue.Visible = false
            end
        end
    end)
end

-- Equipar ferramenta (arma)
local function equipTool()
    if not (Char and Hum) then return end
    if Char:FindFirstChildOfClass('Tool') then return end
    
    -- Procura qualquer ferramenta no Backpack
    for _, tool in ipairs(LP.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            Hum:EquipTool(tool)
            return
        end
    end
end

-- Função para restaurar o personagem ao normal
local function stopEverything()
    statusText = 'Parado'
    pcall(function()
        -- Remove o BodyVelocity que mantém o personagem voando
        if HRP:FindFirstChild("AbacatudoFly") then
            HRP.AbacatudoFly:Destroy()
        end
        -- Restaura colisões
        for _, part in ipairs(Char:GetChildren()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end)
end

-- Teleporte direto (com estabilização de velocidade para evitar detecção)
local function tp(cf)
    if HRP then
        HRP.CFrame = cf
        HRP.Velocity = Vector3.new(0, 0, 0)
        
        -- Garante que o personagem não caia (estilo Fly/Float)
        if _G.AutoFarm or _G.AutoCombat then
            local bv = HRP:FindFirstChild("AbacatudoFly")
            if not bv then
                bv = Instance.new("BodyVelocity")
                bv.Name = "AbacatudoFly"
                bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                bv.Velocity = Vector3.new(0, 0, 0)
                bv.Parent = HRP
            end
        end
    end
end

-- Ataca mob: fica EM CIMA e usa skills/click
local function attackMob(mob)
    if not mob then return end
    local mhrp = mob:FindFirstChild('HumanoidRootPart')
    if not mhrp then return end
    
    equipTool()
    
    -- Ajustado para 8 studs de altura para garantir hitreg
    tp(CFrame.new(mhrp.Position + Vector3.new(0, 8, 0)))
    
    if _G.AutoCombat then 
        for _, k in ipairs({Enum.KeyCode.Z, Enum.KeyCode.X, Enum.KeyCode.C, Enum.KeyCode.V}) do
            pcall(function()
                VIM:SendKeyEvent(true,  k, false, game)
                task.wait(0.01)
                VIM:SendKeyEvent(false, k, false, game)
            end)
        end
    end
end

-- Usa habilidades Z X C V
local function useSkills()
    for _, k in ipairs({Enum.KeyCode.Z, Enum.KeyCode.X, Enum.KeyCode.C, Enum.KeyCode.V}) do
        pcall(function()
            VIM:SendKeyEvent(true,  k, false, game)
            task.wait(0.01)
            VIM:SendKeyEvent(false, k, false, game)
        end)
    end
end

-- Transição Sea 2
local function checkSea()
    if getLevel() >= 700 and game.PlaceId ~= 4442272183 then
        statusText = 'Indo para Sea 2...'
        pcall(function()
            CommF_:InvokeServer('requestEntrance', Vector3.new(-1507.47, 35.55, 1388.27))
        end)
        task.wait(5)
    end
end

-- ══ LOOP PRINCIPAL (INTEGRADO COM COPIA.LUA) ══

local function farmLoop()
    -- Cria suspensão física para não cair
    local float = Instance.new("BodyVelocity")
    float.Name = "FarmFloat"
    float.MaxForce = Vector3.new(0, math.huge, 0)
    float.Velocity = Vector3.new(0, 0, 0)

    while _G.AutoFarm do
        task.wait(0.15) -- Delay para garantir que a UI tenha tempo de processar cliques
        
        if not isAlive() then
            if float.Parent then float.Parent = nil end
            task.wait(3)
            continue
        end

        -- Verifica se precisa ir para o Sea 2
        checkSea()

        -- Mantém a suspensão no HRP
        if HRP and float.Parent ~= HRP then
            float.Parent = HRP
        end

        CheckQuest()
        AutoHaki()
        
        -- Equipar arma selecionada
        local weaponName = _G.SelectWeapon or "Melee"
        if weaponName == "Melee" or weaponName == "Sword" then
            for _, v in pairs(LP.Backpack:GetChildren()) do
                if v:IsA("Tool") and v.ToolTip == weaponName then 
                    weaponName = v.Name 
                    break 
                end
            end
        end
        EquipWeapon(weaponName)

        if not hasQuest() then
            statusText = 'Pegando missão: ' .. (Mon or "...")
            isAcceptingQuest = true
            
            -- Vai até o NPC
            topos(CFrameQuest)
            
            -- Tenta pegar a missão com validação de parâmetros
            if NameQuest and LevelQuest then
                local retryCount = 0
                while not hasQuest() and _G.AutoFarm and retryCount < 3 do
                    pcall(function()
                        CommF_:InvokeServer("StartQuest", NameQuest, LevelQuest)
                    end)
                    task.wait(0.8)
                    retryCount = retryCount + 1
                end
            end
            
            isAcceptingQuest = false
        else
            statusText = 'Matando: ' .. (Mon or "...")
            local mob = findMob(Mon)
            
            if mob then
                -- Teleporta para cima do mob se estiver longe
                local dist = (mob.HumanoidRootPart.Position - HRP.Position).Magnitude
                if dist > 5 then
                    -- Ajustado para 8 studs de altura para garantir hitreg
                    topos(mob.HumanoidRootPart.CFrame * CFrame.new(0, 8, 0))
                end
                
                -- Ataca com pequeno delay para não lagar o input
                AttackNoCD()
                task.wait(0.05)
            else
                -- Vai para o spawn do mob
                topos(CFrameMon * CFrame.new(0, 20, 0))
                task.wait(0.5)
            end
        end
    end
    if float then float:Destroy() end
    statusText = 'Parado'
end

-- Auto Combat independente (sem farm ativo)
task.spawn(function()
    while true do
        task.wait(0.12)
        if _G.AutoCombat and not _G.AutoFarm and isAlive() then
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA('Model') and obj ~= Char
                    and obj:FindFirstChildOfClass('Humanoid')
                    and obj:FindFirstChildOfClass('Humanoid').Health > 0
                    and obj:FindFirstChild('HumanoidRootPart') then
                    if (obj.HumanoidRootPart.Position - HRP.Position).Magnitude < 60 then
                        attackMob(obj)
                        break
                    end
                end
            end
        end
    end
end)

LP.CharacterAdded:Connect(function(c)
    Char = c
    HRP  = c:WaitForChild('HumanoidRootPart')
    Hum  = c:WaitForChild('Humanoid')
end)

stopEverything()

