weaponBtn.MouseButton1Click:Connect(function()
    local current = 1
    for i, v in ipairs(WeaponList) do if v == _G.SelectWeapon then current = i break end end
    current = current + 1
    if current > #WeaponList then current = 1 end
    _G.SelectWeapon = WeaponList[current]
    weaponBtn.Text = 'Arma Atual: ' .. _G.SelectWeapon
end)

-- Auto equip logic para armas específicas
task.spawn(function()
    while true do
        task.wait(1)
        if _G.AutoFarm then
            pcall(function()
                local weaponType = _G.SelectWeapon
                if weaponType == "Melee" then
                    for _, v in pairs(LP.Backpack:GetChildren()) do
                        if v:IsA("Tool") and v.ToolTip == "Melee" then _G.SelectWeapon = v.Name break end
                    end
                elseif weaponType == "Sword" then
                    for _, v in pairs(LP.Backpack:GetChildren()) do
                        if v:IsA("Tool") and v.ToolTip == "Sword" then _G.SelectWeapon = v.Name break end
                    end
                end
            end)
        end
    end
end)

