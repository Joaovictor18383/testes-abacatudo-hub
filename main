ContentArea.Size = UDim2.new(1,-160,1,-34)
ContentArea.BackgroundColor3 = C.content
ContentArea.BorderSizePixel = 0

-- LÓGICA DE ABAS
local menuItems = {'Farm', 'Combat', 'Configurações', 'Status'}
local menuBtns  = {}
local activeTab = 'Farm'

local function makeSideBtn(name)
    local btn = Instance.new('TextButton')
    btn.Size             = UDim2.new(0.9, 0, 0, 34)
    btn.BackgroundColor3 = C.sidebar
    btn.Text             = name
    btn.TextColor3       = C.textDim
    btn.TextSize         = 14
    btn.Font             = Enum.Font.Gotham
    btn.BorderSizePixel  = 0
    btn.Parent           = SideButtons
    Instance.new('UICorner', btn).CornerRadius = UDim.new(0, 6)

    local bar = Instance.new('Frame')
    bar.Size             = UDim2.new(0, 3, 0.6, 0)
    bar.Position         = UDim2.new(0, 0, 0.2, 0)
    bar.BackgroundColor3 = C.accent
    bar.BorderSizePixel  = 0
    bar.Visible          = false
    bar.Parent           = btn
    Instance.new('UICorner', bar).CornerRadius = UDim.new(0, 2)

    return btn, bar
end

for _, name in ipairs(menuItems) do
    local btn, bar = makeSideBtn(name)
    menuBtns[name] = {btn=btn, bar=bar}
end

