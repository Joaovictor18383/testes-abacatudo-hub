local PStatus = newPanel('Status')
local stLvl  = makeInfoLabel(PStatus, '📊 Level: --')
local stMob  = makeInfoLabel(PStatus, '⚔  Mob Atual: --')
local stSea  = makeInfoLabel(PStatus, '🌊 Sea: --')
local stSts  = makeInfoLabel(PStatus, '⚙  Status: Parado')
local stFarm = makeInfoLabel(PStatus, '🌿 Auto Farm: OFF')
local stCbt  = makeInfoLabel(PStatus, '🗡  Auto Combat: OFF')
local stClk  = makeInfoLabel(PStatus, '🖱  Auto Click: OFF')
local stFast = makeInfoLabel(PStatus, '⚡  Fast Attack: OFF')

-- ══ TROCA DE ABAS ══
local function switchTab(name)
    activeTab = name
    TabTitle.Text = name
    for n, p in pairs(Panels) do
        p.Visible = (n == name)
    end
    for n, data in pairs(menuBtns) do
        local active = (n == name)
        data.btn.TextColor3       = active and C.accent or C.textDim
        data.btn.BackgroundColor3 = active and C.selected or C.sidebar
        data.bar.Visible          = active
    end
end

for name, data in pairs(menuBtns) do
    data.btn.MouseButton1Click:Connect(function()
        switchTab(name)
    end)
end

switchTab('Farm')

-- ABRIR / FECHAR
openBtn.MouseButton1Click:Connect(function()
    main.Visible = true
    shadow.Visible = true
    openBtn.Visible = false
    shadowBtn.Visible = false
end)

closeBtn.MouseButton1Click:Connect(function()
    main.Visible = false
    shadow.Visible = false
    openBtn.Visible = true
    shadowBtn.Visible = true
end)

-- DRAG NA JANELA
local dragging, dragStart, startPos
topbar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
        shadow.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X + 6,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y + 6
        )
    end
end)

topbar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- ATUALIZAÇÃO DE INFO
task.spawn(function()
    while true do
        task.wait(1)
        pcall(function()
            local lvl  = getLevel()
            local q    = getQuestEntry()
            local mob  = q and q.mob or '--'
            local sea  = lvl >= 700 and 'Sea 2' or 'Sea 1'
            local sts  = _G.AutoFarm and ('Farmando Lv '..lvl) or statusText

            farmInfoLvl.Text = '📊 Level: ' .. lvl
            farmInfoMob.Text = '⚔  Mob: '   .. mob
            farmInfoSea.Text = '🌊 Sea: '    .. sea
            farmInfoSts.Text = '⚙  Status: ' .. sts

            stLvl.Text  = '📊 Level: '       .. lvl
            stMob.Text  = '⚔  Mob Atual: '   .. mob
            stSea.Text  = '🌊 Sea: '          .. sea
            stSts.Text  = '⚙  Status: '       .. sts
            stFarm.Text = '🌿 Auto Farm: '    .. (_G.AutoFarm   and 'ON ✓' or 'OFF')
            stCbt.Text  = '🗡  Auto Combat: ' .. (_G.AutoCombat and 'ON ✓' or 'OFF')
            stClk.Text  = '🖱  Auto Click: '  .. (_G.AutoClick  and 'ON ✓' or 'OFF')
            stFast.Text = '⚡  Fast Attack: ' .. (_G.FastAttack and 'ON ✓' or 'OFF')
        end)
    end
end)
