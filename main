-- ══════════════════════════════════════
--  UTILITÁRIOS / LÓGICA DE FARM
-- ══════════════════════════════════════
local statusText = 'Parado'

local function getLevel()
    return LP.Data.Level.Value
end

local function isAlive()
    return Char and Hum and Hum.Health > 0
end

local function waitRespawn()
    statusText = 'Aguardando respawn...'
    LP.CharacterAdded:Wait()
    task.wait(3)
    Char = LP.Character
    HRP  = Char:WaitForChild('HumanoidRootPart')
    Hum  = Char:WaitForChild('Humanoid')
end

local function getQuestEntry()
    local lvl = getLevel()
    for _, q in ipairs(QuestData) do
        if lvl >= q.min and lvl <= q.max then return q end
    end
    return QuestData[#QuestData]
end

-- Verifica quest ativa de forma robusta
local function hasQuest()
    local ok, res = pcall(function()
        -- Verifica via dados do jogador
        local qv = LP:FindFirstChild('Data') and LP.Data:FindFirstChild('QuestV2')
        if qv and qv.Value ~= '' then return true end
        
        -- Verifica via GUI (mais confiável em alguns servidores)
        local mainGui = LP.PlayerGui:FindFirstChild('Main')
        local questGui = mainGui and mainGui:FindFirstChild('Quest')
        if questGui and questGui.Visible then return true end
        
        return false
    end)
    return ok and res == true
end

-- Equipar ferramenta (arma)
local function equipTool()
    if not isAlive() then return end
    if Char:FindFirstChildOfClass('Tool') then return end
    
    -- Procura qualquer ferramenta no Backpack
    for _, tool in ipairs(LP.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            Hum:EquipTool(tool)
            return
        end
    end
end

-- Função para restaurar o personagem ao normal
local function stopEverything()
    statusText = 'Parado'
    pcall(function()
        -- Remove o BodyVelocity que mantém o personagem voando
        if HRP:FindFirstChild("AbacatudoFly") then
            HRP.AbacatudoFly:Destroy()
        end
        -- Restaura colisões
        for _, part in ipairs(Char:GetChildren()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end)
end

-- Teleporte direto (com estabilização de velocidade para evitar detecção)
local function tp(cf)
    if HRP then
        HRP.CFrame = cf
        HRP.Velocity = Vector3.new(0, 0, 0)
        
        -- Garante que o personagem não caia (estilo Fly/Float)
        if _G.AutoFarm or _G.AutoCombat then
            local bv = HRP:FindFirstChild("AbacatudoFly")
            if not bv then
                bv = Instance.new("BodyVelocity")
                bv.Name = "AbacatudoFly"
                bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                bv.Velocity = Vector3.new(0, 0, 0)
                bv.Parent = HRP
            end
        end
    end
end

-- Noclip para evitar bugs
task.spawn(function()
    while true do
        task.wait()
        if _G.AutoFarm or _G.AutoCombat then
            pcall(function()
                for _, part in ipairs(Char:GetChildren()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end)
        end
    end
end)

-- Aceita quest: vai até o NPC, espera carregar, invoca servidor
local function doAcceptQuest(q)
    if not _G.AutoQuest then return end
    if hasQuest() then return end
    
    isAcceptingQuest = true
    statusText = 'Pegando missão: ' .. q.mob
    
    -- Tenta pegar a missão por alguns segundos
    local startTime = tick()
    while tick() - startTime < 5 and not hasQuest() and _G.AutoQuest do
        tp(q.qcf)
        pcall(function()
            CommF_:InvokeServer('StartQuest', q.quest, q.qlvl)
        end)
        task.wait(0.5)
    end
    isAcceptingQuest = false
end

-- Encontra mob mais próximo e o agrupa se possível
local function findMob(name)
    local best, bestDist = nil, math.huge
    local enemies = workspace:FindFirstChild("Enemies") or workspace
    
    for _, obj in ipairs(enemies:GetDescendants()) do
        if obj.Name == name and obj:FindFirstChild("HumanoidRootPart") and obj:FindFirstChildOfClass("Humanoid") and obj:FindFirstChildOfClass("Humanoid").Health > 0 then
            local d = (obj.HumanoidRootPart.Position - HRP.Position).Magnitude
            if d < bestDist then
                best, bestDist = obj, d
            end
        end
    end
    return best
end

-- Usa habilidades Z X C V
local function useSkills()
    for _, k in ipairs({Enum.KeyCode.Z, Enum.KeyCode.X, Enum.KeyCode.C, Enum.KeyCode.V}) do
        pcall(function()
            VIM:SendKeyEvent(true,  k, false, game)
            task.wait(0.01)
            VIM:SendKeyEvent(false, k, false, game)
        end)
    end
end

-- Fast Attack / Auto Click Logic
local isAcceptingQuest = false
task.spawn(function()
    while true do
        if (_G.AutoFarm or _G.AutoCombat) and (_G.FastAttack or _G.AutoClick) and not isAcceptingQuest then
            -- Verifica se há algum mob próximo antes de clicar
            local target = nil
            local q = getQuestEntry()
            if q then target = findMob(q.mob) end
            
            if target and (target.HumanoidRootPart.Position - HRP.Position).Magnitude < 50 then
                pcall(function()
                    local tool = Char:FindFirstChildOfClass("Tool")
                    if tool then
                        tool:Activate()
                    end
                    -- VirtualInputManager agora com cliques muito mais rápidos
                    VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                    VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                end)
            end
            
            if _G.FastAttack then
                task.wait() -- Delay mínimo absoluto do Roblox (Fastest possible)
            else
                task.wait(0.1)
            end
        else
            task.wait(0.5)
        end
    end
end)

-- Ataca mob: fica EM CIMA e usa skills/click
local function attackMob(mob)
    if not mob then return end
    local mhrp = mob:FindFirstChild('HumanoidRootPart')
    if not mhrp then return end
    
    equipTool()
    
    -- Ajustado para 8 studs de altura (altura ideal para hitboxes de Blox Fruits)
    tp(CFrame.new(mhrp.Position + Vector3.new(0, 8, 0)))
    
    if _G.AutoCombat then useSkills() end
end

-- Transição Sea 2
local function checkSea()
    if getLevel() >= 700 and game.PlaceId ~= 4442272183 then
        statusText = 'Indo para Sea 2...'
        pcall(function()
            CommF_:InvokeServer('requestEntrance', Vector3.new(-1507.47, 35.55, 1388.27))
        end)
        task.wait(5)
    end
end

-- ══ LOOP PRINCIPAL ══
local function farmLoop()
    while _G.AutoFarm do
        -- Delay estratégico para permitir que a UI respire e não congele
        RunService.Heartbeat:Wait()
        
        if not isAlive() then waitRespawn() continue end

        checkSea()

        local q = getQuestEntry()

        -- Entrada de ilha especial
        if q.ent then
            local dist = (q.qcf.Position - HRP.Position).Magnitude
            if dist > 3000 then
                statusText = 'Teleportando para ilha...'
                pcall(function() CommF_:InvokeServer('requestEntrance', q.ent) end)
                task.wait(2)
            end
        end

        -- Pega quest se não tiver
        if _G.AutoQuest and not hasQuest() then
            doAcceptQuest(q)
        end

        -- Mata mobs enquanto tiver quest (ou se autoquest estiver off)
        local mob = findMob(q.mob)
        if mob then
            statusText = 'Matando: ' .. q.mob
            attackMob(mob)
        else
            -- Mob não encontrado: vai para a área base
            statusText = 'Procurando: ' .. q.mob
            tp(q.mcf * CFrame.new(0, 20, 0))
            task.wait(0.5)
        end
    end
    stopEverything()
end

-- Auto Combat independente (sem farm ativo)
task.spawn(function()
    while true do
        task.wait(0.12)
        if _G.AutoCombat and not _G.AutoFarm and isAlive() then
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA('Model') and obj ~= Char
                    and obj:FindFirstChildOfClass('Humanoid')
                    and obj:FindFirstChildOfClass('Humanoid').Health > 0
                    and obj:FindFirstChild('HumanoidRootPart') then
                    if (obj.HumanoidRootPart.Position - HRP.Position).Magnitude < 60 then
                        attackMob(obj)
                        break
                    end
                end
            end
        end
    end
end)

LP.CharacterAdded:Connect(function(c)
    Char = c
    HRP  = c:WaitForChild('HumanoidRootPart')
    Hum  = c:WaitForChild('Humanoid')
end)

stopEverything()

