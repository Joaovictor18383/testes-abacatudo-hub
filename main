-- Painéis com Scrolling e Layout Automático
local Panels = {}
local function newPanel(name)
    local p = Instance.new('ScrollingFrame')
    p.Name             = name
    p.Size             = UDim2.new(1, -10, 1, -54)
    p.Position         = UDim2.new(0, 5, 0, 48)
    p.BackgroundTransparency = 1
    p.BorderSizePixel  = 0
    p.ScrollBarThickness = 2
    p.ScrollBarImageColor3 = C.accent
    p.Visible          = false
    p.Parent           = ContentArea
    p.CanvasSize       = UDim2.new(0, 0, 0, 0)
    p.AutomaticCanvasSize = Enum.AutomaticSize.Y
    p.Selectable       = false
    p.Active           = true -- Ativado para permitir scroll, mas sem bloquear cliques nos filhos
    
    local layout = Instance.new("UIListLayout", p)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 8)
    
    local padding = Instance.new("UIPadding", p)
    padding.PaddingLeft = UDim.new(0, 10)
    padding.PaddingRight = UDim.new(0, 10)
    padding.PaddingTop = UDim.new(0, 5)
    padding.PaddingBottom = UDim.new(0, 10)

    Panels[name]       = p
    return p
end

-- Helpers de Widget (Estilo Switch com Descrição - Igual à Imagem)
local allToggles = {}
local function makeRow(parent, label, desc, flag, callback)
    local row = Instance.new('Frame')
    row.Size             = UDim2.new(1, 0, 0, 56)
    row.BackgroundColor3 = Color3.fromRGB(22, 22, 25)
    row.BorderSizePixel  = 0
    row.Parent           = parent
    row.Active           = false -- Frame não deve bloquear o botão interno
    Instance.new('UICorner', row).CornerRadius = UDim.new(0, 8)

    local stroke = Instance.new("UIStroke", row)
    stroke.Color = Color3.fromRGB(40, 40, 45)
    stroke.Thickness = 1
    stroke.Transparency = 0.5

    -- Título da opção
    local lbl = Instance.new('TextLabel')
    lbl.Size                   = UDim2.new(1, -80, 0, 22)
    lbl.Position               = UDim2.new(0, 14, 0, 10)
    lbl.BackgroundTransparency = 1
    lbl.Text                   = label
    lbl.TextColor3             = C.text
    lbl.TextSize               = 15
    lbl.Font                   = Enum.Font.GothamBold
    lbl.TextXAlignment         = Enum.TextXAlignment.Left
    lbl.Active                 = false
    lbl.Parent                 = row

    -- Descrição (Subtitle)
    local sub = Instance.new('TextLabel')
    sub.Size                   = UDim2.new(1, -80, 0, 16)
    sub.Position               = UDim2.new(0, 14, 0, 30)
    sub.BackgroundTransparency = 1
    sub.Text                   = desc
    sub.TextColor3             = C.textDim
    sub.TextSize               = 12
    sub.Font                   = Enum.Font.Gotham
    sub.TextXAlignment         = Enum.TextXAlignment.Left
    sub.Active                 = false
    sub.Parent                 = row

    -- Switch (Pílula moderna)
    local switchBg = Instance.new('Frame')
    switchBg.Size             = UDim2.new(0, 42, 0, 22)
    switchBg.Position         = UDim2.new(1, -56, 0.5, -11)
    switchBg.BackgroundColor3 = C.btnOff
    switchBg.BorderSizePixel  = 0
    switchBg.Active           = false
    switchBg.Parent           = row
    Instance.new('UICorner', switchBg).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new('Frame')
    knob.Size             = UDim2.new(0, 16, 0, 16)
    knob.Position         = UDim2.new(0, 3, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(180, 180, 180)
    knob.BorderSizePixel  = 0
    knob.Active           = false
    knob.Parent           = switchBg
    Instance.new('UICorner', knob).CornerRadius = UDim.new(1, 0)

    local function updateVisuals()
        local s = _G[flag]
        TweenService:Create(switchBg, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            BackgroundColor3 = s and C.accent or C.btnOff
        }):Play()
        TweenService:Create(knob, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Position = s and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
            BackgroundColor3 = s and Color3.new(1, 1, 1) or Color3.fromRGB(180, 180, 180)
        }):Play()
    end

    if not allToggles[flag] then allToggles[flag] = {} end
    table.insert(allToggles[flag], updateVisuals)
    updateVisuals()

    local btn = Instance.new('TextButton')
    btn.Size                   = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text                   = ''
    btn.ZIndex                 = 5 -- Botão por cima de tudo no frame
    btn.Parent                 = row

    btn.MouseButton1Click:Connect(function()
        _G[flag] = not _G[flag]
        for _, func in ipairs(allToggles[flag]) do
            pcall(func)
        end
        if callback then pcall(callback, _G[flag]) end
    end)

    return row
end

local function makeInfoLabel(parent, txt)
    local lbl = Instance.new('TextLabel')
    lbl.Size                   = UDim2.new(1, 0, 0, 24)
    lbl.BackgroundTransparency = 1
    lbl.Text                   = txt
    lbl.TextColor3             = C.textDim
    lbl.TextSize               = 13
    lbl.Font                   = Enum.Font.Gotham
    lbl.TextXAlignment         = Enum.TextXAlignment.Left
    lbl.Active                 = false
    lbl.Parent                 = parent
    return lbl
end

-- ══ PAINEL: FARM ══
local PFarm = newPanel('Farm')

-- Novo Toggle de Auto Farm (Substituindo o botão antigo)
makeRow(PFarm, 'Auto Farm Principal', 'Ativa o sistema de farm automático', 'AutoFarm', function(state)
    if state then
        _G.AutoClick = true
        _G.FastAttack = true
        for _, flag in ipairs({"AutoClick", "FastAttack"}) do
            if allToggles[flag] then
                for _, func in ipairs(allToggles[flag]) do pcall(func) end
            end
        end
        task.spawn(farmLoop)
    else
        stopEverything()
    end
end)

makeRow(PFarm, 'Auto Quest',    'Completa missões automaticamente', 'AutoQuest')
makeRow(PFarm, 'Fast Attack',   'Aumenta a velocidade de ataque',   'FastAttack')
makeRow(PFarm, 'Auto Click',    'Clica automaticamente nos inimigos', 'AutoClick')

local farmInfoLvl = makeInfoLabel(PFarm, '📊 Level: --')
local farmInfoMob = makeInfoLabel(PFarm, '⚔  Mob: --')
local farmInfoSea = makeInfoLabel(PFarm, '🌊 Sea: --')
local farmInfoSts = makeInfoLabel(PFarm, '⚙  Status: Parado')

